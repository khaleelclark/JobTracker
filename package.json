{
  "name": "job-tracker",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "concurrently \"pnpm dev:web\" \"pnpm dev:mcp\"",
    "dev:web": "pnpm --filter @job-tracker/web dev",
    "dev:mcp": "pnpm --filter @job-tracker/mcp-server dev",
    "db:migrate": "tsx scripts/dbMigrate.ts",
    "db:deploy": "tsx scripts/dbDeploy.ts",
    "db:studio": "tsx scripts/dbStudio.ts",
    "backup:run": "tsx scripts/backup.ts",
    "init:data-dir": "tsx scripts/initDataDir.ts",
    "resume:pdf": "node scripts/generateResumePdf.js",
    "test:invariants": "node --test tests/invariants.test.mjs",
    "test:crud": "node --test tests/crud.test.mjs",
    "test:api": "cd apps/web && TSX_TSCONFIG=tsconfig.json node --import tsx --test ../../tests/api-crud.test.ts",
    "test:mcp": "node --import tsx --test tests/mcp-full-context.test.ts",
    "test:mcp-db-selection": "node --import tsx --test tests/mcp-database-selection.test.ts",
    "test": "pnpm test:invariants && pnpm test:crud && pnpm test:api && pnpm test:mcp && pnpm test:mcp-db-selection"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  }
}
