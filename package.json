{
  "name": "job-tracker",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "concurrently \"pnpm dev:web\" \"pnpm dev:mcp\"",
    "dev:web": "pnpm --filter @job-tracker/web dev",
    "dev:mcp": "pnpm --filter @job-tracker/mcp-server dev",
    "ollama:serve:cpu": "powershell -ExecutionPolicy Bypass -File scripts/ollamaServeCpu.ps1",
    "ollama:serve:cpu:sh": "bash scripts/ollamaServeCpu.sh",
    "db:migrate": "tsx scripts/dbMigrate.ts",
    "db:studio": "tsx scripts/dbStudio.ts",
    "worker:run": "pnpm --filter @job-tracker/web worker:run",
    "backup:run": "tsx scripts/backup.ts",
    "init:data-dir": "tsx scripts/initDataDir.ts",
    "test:invariants": "node --test tests/invariants.test.mjs",
    "test:crud": "node --test tests/crud.test.mjs",
    "test": "pnpm test:invariants && pnpm test:crud"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  }
}
