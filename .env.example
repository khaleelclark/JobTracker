# Shared
JOBTRACKER_DATA_DIR=
# Optional override. If blank, code auto-detects OS app-data path.
DATABASE_URL=

# Optional: override where generated resume PDFs are saved on your machine.
# Defaults to ~/Documents/Job App Resumes. Set this if you want a different folder.
RESUME_OUTPUT_DIR=

# MCP
MCP_PORT=7331
# Optional public HTTPS base URL for external MCP clients.
# Examples:
#   https://mcp.example.com
#   https://your-tunnel.example
MCP_BASE_URL=
OAUTH_CLIENT_ID=replace-me
OAUTH_CLIENT_SECRET=replace-me

# Optional helper for users who choose ngrok specifically.
NGROK_AUTHTOKEN=
