# Shared
JOBTRACKER_DATA_DIR=
# Optional override. If blank, code auto-detects OS app-data path.
DATABASE_URL=

# Web
# Runtime options: lmstudio | ollama | llamacpp | openai
LLM_RUNTIME=lmstudio
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLAMACPP_BASE_URL=http://127.0.0.1:8080
LMSTUDIO_BASE_URL=http://127.0.0.1:1234
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_MODEL=openai/gpt-oss-20b
LLM_REQUEST_TIMEOUT_MS=20000
LOCAL_LLM_PROMPT_ONLY=true
LOCAL_LLM_MAX_BODY_CHARS=220
LLM_WORKER_INTERVAL_HOURS=6
LLM_WORKER_MIN_GAP_MINUTES=10

# MCP
MCP_PORT=7331
# Optional public HTTPS base URL for external MCP clients.
# Examples:
#   https://mcp.example.com
#   https://your-tunnel.example
MCP_BASE_URL=
OAUTH_CLIENT_ID=replace-me
OAUTH_CLIENT_SECRET=replace-me

# Optional helper for users who choose ngrok specifically.
NGROK_AUTHTOKEN=
